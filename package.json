{
  "name": "voice-bridge",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @voice-bridge/web run dev -- --host",
    "dev:server": "cargo run -p voice-bridge-server -- serve",
    "gen:types": "cargo run -p voice-bridge-server -- export-types",
    "dev:tauri": "pnpm --filter @voice-bridge/tauri tauri android dev",
    "typecheck": "pnpm -w exec tsc -p packages/shared/tsconfig.json --noEmit && pnpm -w exec tsc -p packages/app/tsconfig.json --noEmit && pnpm --filter @voice-bridge/web run typecheck && pnpm --filter @voice-bridge/tauri run typecheck",
    "build:web": "pnpm --filter @voice-bridge/web run build",
    "build:server": "cargo build -p voice-bridge-server --release",
    "build:tauri-ui": "pnpm --filter @voice-bridge/tauri run build",
    "build:tauri": "pnpm --filter @voice-bridge/tauri tauri android build",
    "init:tauri": "pnpm --filter @voice-bridge/tauri tauri android init"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
